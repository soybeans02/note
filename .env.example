# Copy to .env.local (gitignored) for local dev, or paste into GitHub
# repo Secrets with the same VITE_ names for the deployed site.
# Every variable is OPTIONAL — if absent the related feature is disabled
# and the app continues to work offline.

# ─── Password gate ────────────────────────────────────────────────────
# SHA-256 of the password the app asks for on first open.
# Generate via: npm run set-password   (writes this file for you).
# Leave unset → no gate.
VITE_NOTE_PASSWORD_HASH=

# ─── AWS S3 sync (folders, documents, annotations, blobs) ──────────────
# Use an IAM user scoped to just this bucket with PutObject / GetObject /
# DeleteObject / ListBucket. The bucket needs a CORS rule that allows
# GET/PUT/DELETE from the deploy origin (and http://localhost:5273 for
# dev). Leave any of these unset → sync is disabled (offline-only).
VITE_AWS_REGION=
VITE_AWS_BUCKET=
VITE_AWS_ACCESS_KEY_ID=
VITE_AWS_SECRET_ACCESS_KEY=
# Optional: custom endpoint (e.g. for Cloudflare R2 or other S3-compatible
# providers). For real AWS S3 leave this blank.
VITE_AWS_S3_ENDPOINT=
# Optional: folder prefix inside the bucket so you can share one bucket
# across apps. Trailing slash not required.
VITE_AWS_S3_PREFIX=
